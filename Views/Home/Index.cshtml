        btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Übersetzen';
    }
}

async function trKopieren() {
    const a = document.getElementById('trAusgabe'); const btn = document.getElementById('trBtnCopy');
    if (!a.value) return;
    try { await navigator.clipboard.writeText(a.value); }
    catch { a.select(); document.execCommand('copy'); }
    btn.innerHTML = '<i class="bi bi-check"></i> Kopiert';
    setTimeout(() => { btn.innerHTML = '<i class="bi bi-clipboard"></i> Kopieren'; }, 2000);
}

