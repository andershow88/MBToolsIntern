async function trStatusLaden() {
    const banner = document.getElementById('trStatus');
    const box = document.getElementById('trVerbrauchBox');
    const label = document.getElementById('trVerbrauchLabel');
    const bar = document.getElementById('trVerbrauchBar');
    try {
        const r = await fetch('/api/DeeplStatus?typ=' + encodeURIComponent(_trModus));
        const d = await r.json();
        if (!d.konfiguriert) {
            banner.style.display = 'block';
            banner.style.background = 'rgba(222,98,80,.1)';
            banner.style.color = 'var(--mc-warning)';
            const keyFeld = _trModus === 'free' ? 'DeepLApiKeyFree' : 'DeepLApiKey';
            const envVar = _trModus === 'free' ? 'DEEPL_API_KEY_FREE' : 'DEEPL_API_KEY';
            banner.innerHTML = `<i class="bi bi-exclamation-triangle-fill"></i> <strong>${_trModus === 'free' ? 'Test-API' : 'Pro-API'} noch nicht konfiguriert.</strong> Hinterlege den API-Key in <code style="background:rgba(0,0,0,.06);padding:.05rem .3rem;border-radius:3px;">appsettings.json</code> (Feld <code style="background:rgba(0,0,0,.06);padding:.05rem .3rem;border-radius:3px;">${keyFeld}</code>) oder als Umgebungsvariable <code style="background:rgba(0,0,0,.06);padding:.05rem .3rem;border-radius:3px;">${envVar}</code>, dann App-Pool neu starten.`;
            box.style.display = 'none';
            return false;
        }
        banner.style.display = 'none';
        if (d.fehler) {
            box.style.display = 'block';
            label.innerHTML = '<span style="color:var(--mc-danger);">' + d.fehler + '</span>';
            bar.style.width = '0%';
            return true;
        }
        box.style.display = 'block';
        const v = d.verbraucht.toLocaleString('de-DE');
        const l = d.limit ? d.limit.toLocaleString('de-DE') : '∞';
        label.innerHTML = `${v} / ${l} Zeichen <span style="color:var(--mc-text-muted);">· ${d.prozent}%</span>`;
        bar.style.width = Math.min(d.prozent, 100) + '%';
        bar.classList.remove('warn', 'danger');
        if (d.prozent > 90) bar.classList.add('danger');
        else if (d.prozent > 75) bar.classList.add('warn');
        return true;
    } catch (e) {
        banner.style.display = 'block';
        banner.style.background = 'rgba(167,12,35,.08)'; banner.style.color = 'var(--mc-danger)';
        banner.innerHTML = '<i class="bi bi-x-circle"></i> Status-Abfrage fehlgeschlagen.';
        return false;
    }
}

function trSpracheTauschen() {
    const q = document.getElementById('trQuelle'); const z = document.getElementById('trZiel');
    if (q.value === 'AUTO') return;
    const qBase = q.value.split('-')[0]; const zBase = z.value.split('-')[0];
    if ([...z.options].some(o => o.value === q.value)) z.value = q.value;
    else if ([...z.options].some(o => o.value.startsWith(qBase))) z.value = [...z.options].find(o => o.value.startsWith(qBase)).value;
    if ([...q.options].some(o => o.value === zBase)) q.value = zBase;
    localStorage.setItem('mc-tr-quelle', q.value);
    localStorage.setItem('mc-tr-ziel', z.value);
    const e = document.getElementById('trEingabe').value; const a = document.getElementById('trAusgabe').value;
    document.getElementById('trEingabe').value = a; document.getElementById('trAusgabe').value = e;
    trZeichenZaehlen();
}

function trTabWechseln(modus) {
    document.getElementById('trTabText').classList.toggle('tr-tab-aktiv', modus === 'text');
    document.getElementById('trTabFile').classList.toggle('tr-tab-aktiv', modus === 'file');
    document.getElementById('trBereichText').style.display = modus === 'text' ? 'grid' : 'none';
    document.getElementById('trBereichFile').style.display = modus === 'file' ? 'block' : 'none';
}

function trZeichenZaehlen() {
