async function trDateiUebersetzen() {
    if (!trDatei) return;
    const ziel = document.getElementById('trZiel').value;
    const quelle = document.getElementById('trQuelle').value;
    const btn = document.getElementById('trBtnFile');
    const res = document.getElementById('trDateiResult');
    btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Übersetze… (kann 30 s+ dauern)';
    res.style.display = 'block';
    res.innerHTML = `<div style="display:flex;align-items:center;gap:.75rem;color:var(--mc-text-muted);"><div style="width:18px;height:18px;border:2px solid var(--mc-border);border-top-color:var(--mc-petrol);border-radius:50%;animation:spin .8s linear infinite;"></div> Dokument wird an DeepL gesendet…</div>`;
    try {
        const fd = new FormData();
        fd.append('datei', trDatei); fd.append('ziel', ziel); fd.append('quelle', quelle); fd.append('typ', _trModus);
        const r = await fetch('/api/TranslateDocument', { method: 'POST', body: fd });
        const d = await r.json();
        if (d.error) { res.innerHTML = `<div style="color:var(--mc-danger);"><i class="bi bi-exclamation-triangle"></i> ${d.error}</div>`; return; }
        const bin = atob(d.data); const bytes = new Uint8Array(bin.length);
        for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
        trDateiBlob = new Blob([bytes]); trDateiName = d.dateiname;
        res.innerHTML = `<div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;">
            <i class="bi bi-check-circle-fill" style="color:var(--mc-success);font-size:1.3rem;"></i>
            <div><strong>${d.dateiname}</strong> <span style="color:var(--mc-text-muted);font-size:.8rem;">· ${(d.groesse/1024).toFixed(0)} KB</span></div>
            <button class="tr-action-btn tr-action-primary" onclick="mcSpeichern(trDateiBlob, trDateiName)" style="margin-left:auto;"><i class="bi bi-download"></i> Herunterladen</button>
        </div>`;
        trStatusLaden();
    } catch (e) {
        res.innerHTML = '<div style="color:var(--mc-danger);">Verbindungsfehler bei der Übersetzung.</div>';
    } finally {
        btn.disabled = false; btn.innerHTML = '<i class="bi bi-translate"></i> Dokument übersetzen';
    }
}

