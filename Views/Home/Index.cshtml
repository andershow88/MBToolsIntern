    btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Übersetze…';
    document.getElementById('trAusgabe').value = '';
    document.getElementById('trErkannt').textContent = '';
    try {
        const fd = new FormData();
        fd.append('text', text); fd.append('ziel', ziel); fd.append('quelle', quelle); fd.append('typ', _trModus);
        const r = await fetch('/api/Translate', { method: 'POST', body: fd });
        const d = await r.json();
        if (d.error) { mcError(d.error); return; }
        document.getElementById('trAusgabe').value = d.text;
