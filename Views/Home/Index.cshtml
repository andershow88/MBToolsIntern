}

async function trTextUebersetzen() {
    const text = document.getElementById('trEingabe').value.trim();
    if (!text) { mcAlert('Bitte einen Text eingeben.', { variante: 'warn', icon: 'bi-fonts' }); return; }
    const ziel = document.getElementById('trZiel').value;
    const quelle = document.getElementById('trQuelle').value;
