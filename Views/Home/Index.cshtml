@section Scripts {
<script>
// Globale Tool-Verwaltung
let _aktivesTool = null;
const ALLE_TOOLS = ['encrypt','convert','text','ocr','translate','split','merge','info'];
const TOOL_ZU_HOLDER = {
    encrypt: 'holder-pdf', convert: 'holder-pdf', text: 'holder-pdf',
    split:   'holder-pdf', merge:   'holder-pdf', info:  'holder-pdf',
    translate: 'holder-uebersetzen',
    ocr:       'holder-spielwiese'
};

function toolOeffnen(id, modus) {
    // Sonderfall Translate: gleiche Kachel + gleicher Modus → toggeln zu
    if (id === 'translate' && modus) {
        if (_aktivesTool === 'translate' && _trModus === modus) { toolSchliessen('translate'); return; }
        if (_aktivesTool === 'translate' && _trModus !== modus) { trSetzeModus(modus); return; }
    }
    // Toggle für andere Tools
    if (_aktivesTool === id && id !== 'translate') { toolSchliessen(id); return; }
    if (_aktivesTool && _aktivesTool !== id) toolSchliessen(_aktivesTool);

    const panel = document.getElementById('panel-' + id);
    if (!panel) return;

    const holderId = TOOL_ZU_HOLDER[id];
    const holder = holderId ? document.getElementById(holderId) : null;
    if (holder && panel.parentElement !== holder) holder.appendChild(panel);

    panel.style.display = '';
    if (id === 'translate' && modus) trSetzeModus(modus);

    setTimeout(() => {
        const topbarH = document.querySelector('.mc-topbar')?.offsetHeight || 64;
        const y = panel.getBoundingClientRect().top + window.pageYOffset - topbarH - 12;
        window.scrollTo({ top: y, behavior: 'smooth' });
    }, 30);
    _aktivesTool = id;
}
function toolSchliessen(id) {
    const panel = document.getElementById('panel-' + id);
    if (panel) panel.style.display = 'none';
    toolReset(id);
    if (_aktivesTool === id) _aktivesTool = null;
}
function toolReset(id) {
    switch (id) {
        case 'encrypt':   encryptReset();   break;
        case 'merge':     mergeReset();     break;
        case 'split':     splitReset();     break;
        case 'text':      textReset();      break;
        case 'ocr':       ocrReset();       break;
        case 'translate': translateReset(); break;
        case 'info':      infoReset();      break;
        case 'convert':   convertReset();   break;
    }
}

