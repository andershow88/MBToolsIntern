@{ ViewData["Title"] = "Dokumenten-Tools"; }

<!-- ═══ MerkurTools — PDF Werkzeuge ═══ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-tools"></i> MerkurTools — PDF Werkzeuge</div>
    <div class="tool-grid">
        <div class="tool-card" onclick="toolOeffnen('encrypt')">
            <div class="tool-icon" style="background:#A70C23;"><i class="bi bi-shield-lock"></i></div>
            <div><div class="tool-name">PDF verschlüsseln</div><div class="tool-desc">PDF mit AES-256 verschlüsseln, sicheres Zufallspasswort wird einmalig angezeigt</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('convert')">
            <div class="tool-icon" style="background:#DE6250;"><i class="bi bi-file-earmark-arrow-down"></i></div>
            <div><div class="tool-name">Dokument → PDF</div><div class="tool-desc">Word, Excel, PowerPoint, OpenDocument als PDF konvertieren</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('text')">
            <div class="tool-icon" style="background:#A2AE3C;"><i class="bi bi-body-text"></i></div>
            <div><div class="tool-name">Text aus PDF extrahieren</div><div class="tool-desc">Den gesamten Text eines PDFs als Klartext ausgeben</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('split')">
            <div class="tool-icon" style="background:var(--mc-gold);"><i class="bi bi-scissors"></i></div>
            <div><div class="tool-name">PDF aufteilen</div><div class="tool-desc">Seiten aus einem PDF extrahieren oder den Seitenbereich auswählen</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('merge')">
            <div class="tool-icon"><i class="bi bi-files"></i></div>
            <div><div class="tool-name">PDFs zusammenführen</div><div class="tool-desc">Mehrere PDF-Dateien zu einem Dokument zusammenfügen</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('info')">
            <div class="tool-icon" style="background:#6C4562;"><i class="bi bi-info-circle"></i></div>
            <div><div class="tool-name">PDF-Informationen</div><div class="tool-desc">Metadaten anzeigen: Seitenanzahl, Autor, Erstelldatum, Dateigröße</div></div>
        </div>
    </div>
    <div class="panel-holder" id="holder-pdf"></div>
</section>

<!-- ═══ MerkurTools — Übersetzungen ═══ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-translate"></i> MerkurTools — Übersetzungen</div>
    <div class="tool-grid">
        <div class="tool-card tool-card-translate" onclick="toolOeffnen('translate', 'free')">
            <div class="tool-icon" style="background:linear-gradient(135deg,#7B8FE0,#5B6BC0);"><i class="bi bi-translate"></i></div>
            <div style="flex:1;">
                <div class="tool-name">DeepL Test API <span class="tool-pill tool-pill-free">FREE</span></div>
                <div class="tool-desc">Kostenloser Test-Schlüssel — 1 Mio. Zeichen/Monat (1 Zeichen = 1 Credit), ideal zum Ausprobieren</div>
            </div>
        </div>
        <div class="tool-card tool-card-translate" onclick="toolOeffnen('translate', 'pro')">
            <div class="tool-icon" style="background:linear-gradient(135deg,#5B6BC0,#3D4D9C);"><i class="bi bi-translate"></i></div>
            <div style="flex:1;">
                <div class="tool-name">DeepL Pro Advanced <span class="tool-pill tool-pill-pro">PRO</span></div>
                <div class="tool-desc">Lizenzierter Pro-Schlüssel — höchste Qualität, ohne monatliches Limit, EU-Hosting mit DPA</div>
            </div>
        </div>
    </div>
    <div class="panel-holder" id="holder-uebersetzen"></div>
</section>

<!-- ═══ MerkurTools — Künstliche Intelligenz ═══ -->
<section class="mc-section">
    <div class="mc-section-title"><i class="bi bi-stars"></i> MerkurTools — Künstliche Intelligenz</div>
    <div class="tool-grid">
        <div class="tool-card" onclick="toolOeffnen('kichat')">
            <div class="tool-icon" style="background:linear-gradient(135deg,#10A37F,#1A7F64);"><i class="bi bi-chat-dots"></i></div>
            <div><div class="tool-name">Chat (OpenAI)</div><div class="tool-desc">Frage stellen, Dialog führen — läuft via Proxy gegen OpenAI, Markdown-Antworten</div></div>
        </div>
        <div class="tool-card" onclick="toolOeffnen('kiurl')">
            <div class="tool-icon" style="background:linear-gradient(135deg,#39747A,#10A37F);"><i class="bi bi-globe2"></i></div>
            <div><div class="tool-name">URL analysieren</div><div class="tool-desc">Webseite laden lassen und zusammenfassen, übersetzen, erklären oder Fragen dazu stellen</div></div>
        </div>
    </div>
    <div class="panel-holder" id="holder-ki"></div>
</section>

<!-- ═══ MerkurTools — Testzwecke / Spielwiese ═══ -->
<section class="mc-section">
    <div class="mc-section-title" style="border-bottom-color:var(--mc-warning);"><i class="bi bi-flask" style="color:var(--mc-warning) !important;"></i> MerkurTools — Testzwecke / Spielwiese</div>
    <div style="font-size:.78rem;color:var(--mc-text-muted);margin-top:-.6rem;margin-bottom:1rem;">Experimentelle Werkzeuge — Qualität nicht produktionsreif. Nutzung auf eigene Verantwortung.</div>
    <div class="tool-grid">
        <div class="tool-card" onclick="toolOeffnen('ocr')">
            <div class="tool-icon" style="background:#39747A;"><i class="bi bi-fonts"></i></div>
            <div><div class="tool-name">Text aus Scan / Handschrift</div><div class="tool-desc">OCR für eingescannte PDFs — Druckschrift mässig, Handschrift fast nicht zu gebrauchen</div></div>
        </div>
    </div>
    <div class="panel-holder" id="holder-spielwiese"></div>
</section>

<!-- PDF verschlüsseln -->
<section class="mc-section" id="panel-encrypt" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-shield-lock"></i> PDF verschlüsseln <button onclick="toolSchliessen('encrypt')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" onclick="document.getElementById('encryptFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');encryptStart(event.dataTransfer.files[0])">
            <i class="bi bi-shield-lock" style="font-size:2.5rem; color:#A70C23;"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">PDF hierher ziehen oder klicken</div>
            <div style="font-size:.75rem; color:var(--mc-text-muted); margin-top:.35rem;">Verschlüsselung mit AES-256 · neues Zufallspasswort pro Datei</div>
            <input type="file" id="encryptFile" accept=".pdf" style="display:none;" onchange="encryptStart(this.files[0])" />
        </div>
        <div class="result-card" id="encryptResult"></div>
    </div>
</section>

<!-- ═══ Tool-Panels ═══ -->

<!-- PDF zusammenführen -->
<section class="mc-section" id="panel-merge" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-files"></i> PDFs zusammenführen <button onclick="toolSchliessen('merge')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" id="mergeZone" onclick="document.getElementById('mergeFiles').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');mergeAddFiles(event.dataTransfer.files)">
            <i class="bi bi-file-earmark-pdf" style="font-size:2.5rem; color:var(--mc-petrol);"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">PDFs hierher ziehen oder klicken (mindestens 2)</div>
            <input type="file" id="mergeFiles" accept=".pdf" multiple style="display:none;" onchange="mergeAddFiles(this.files)" />
        </div>
        <div class="file-list" id="mergeList"></div>
        <div style="margin-top:1rem; display:flex; gap:.75rem;">
            <button class="btn-mc btn-mc-filled" onclick="mergeStart()" id="mergeBtn"><i class="bi bi-files"></i> Zusammenführen</button>
            <button class="btn-mc btn-mc-outline" onclick="mergeClear()"><i class="bi bi-trash"></i> Alle entfernen</button>
        </div>
        <div class="result-card" id="mergeResult"></div>
    </div>
</section>

<!-- PDF aufteilen -->
<section class="mc-section" id="panel-split" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-scissors"></i> PDF aufteilen <button onclick="toolSchliessen('split')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" onclick="document.getElementById('splitFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');splitSetFile(event.dataTransfer.files[0])">
            <i class="bi bi-file-earmark-pdf" style="font-size:2.5rem; color:var(--mc-gold);"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">PDF hierher ziehen oder klicken</div>
            <input type="file" id="splitFile" accept=".pdf" style="display:none;" onchange="splitSetFile(this.files[0])" />
        </div>
        <div id="splitInfo" style="display:none; margin-top:1rem;">
            <div id="splitFileName" style="font-weight:600; margin-bottom:.75rem;"></div>
            <div style="display:flex; gap:.75rem; align-items:end; flex-wrap:wrap;">
                <div><label style="font-size:.8rem; color:var(--mc-text-muted);">Von Seite</label><input type="number" id="splitVon" min="1" value="1" style="display:block; width:80px; padding:.4rem .6rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm);" /></div>
                <div><label style="font-size:.8rem; color:var(--mc-text-muted);">Bis Seite</label><input type="number" id="splitBis" min="1" style="display:block; width:80px; padding:.4rem .6rem; border:1px solid var(--mc-border); border-radius:var(--mc-radius-sm);" /></div>
                <button class="btn-mc btn-mc-filled" onclick="splitStart()"><i class="bi bi-scissors"></i> Extrahieren</button>
            </div>
        </div>
    </div>
</section>

<!-- Text extrahieren -->
<section class="mc-section" id="panel-text" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-body-text"></i> Text aus PDF <button onclick="toolSchliessen('text')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" onclick="document.getElementById('textFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');textExtract(event.dataTransfer.files[0])">
            <i class="bi bi-body-text" style="font-size:2.5rem; color:#A2AE3C;"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">PDF hierher ziehen oder klicken</div>
            <input type="file" id="textFile" accept=".pdf" style="display:none;" onchange="textExtract(this.files[0])" />
        </div>
        <div class="result-card" id="textResult"></div>
    </div>
</section>

<!-- Übersetzen (DeepL) -->
<section class="mc-section" id="panel-translate" style="display:none;">
    <div class="tr-card">

        <!-- Header mit Branding & Modus & Verbrauch -->
        <div class="tr-header">
            <div class="tr-header-left">
                <div class="tr-logo"><i class="bi bi-translate"></i></div>
                <div>
                    <div class="tr-title" id="trTitel">DeepL Pro Advanced</div>
                    <div class="tr-subtitle">Powered by DeepL · höchste Übersetzungsqualität für 30+ Sprachen</div>
                </div>
                <span class="tr-mode-badge" id="trModeBadge">PRO</span>
            </div>
            <div class="tr-header-right">
                <div id="trVerbrauchBox" class="tr-usage" style="display:none;">
                    <div class="tr-usage-text"><i class="bi bi-bar-chart-line"></i> <span id="trVerbrauchLabel">—</span></div>
                    <div class="tr-usage-bar"><div class="tr-usage-fill" id="trVerbrauchBar"></div></div>
                </div>
                <button class="tr-close" onclick="toolSchliessen('translate')" title="Schliessen"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <!-- Status-Banner: API-Key fehlt? -->
        <div id="trStatus" class="tr-banner" style="display:none;"></div>

        <!-- Sprachauswahl -->
        <div class="tr-language-row">
            <div class="tr-lang-wrap">
                <label class="tr-lang-label">Von</label>
                <select id="trQuelle" class="tr-lang-select"></select>
            </div>
            <button class="tr-swap" onclick="trSpracheTauschen()" title="Sprachen tauschen"><i class="bi bi-arrow-left-right"></i></button>
            <div class="tr-lang-wrap">
                <label class="tr-lang-label">Nach</label>
                <select id="trZiel" class="tr-lang-select"></select>
            </div>
        </div>

        <!-- Tab-Switch -->
        <div class="tr-tabs">
            <button class="tr-tab tr-tab-aktiv" id="trTabText" onclick="trTabWechseln('text')"><i class="bi bi-fonts"></i><span>Text</span></button>
            <button class="tr-tab" id="trTabFile" onclick="trTabWechseln('file')"><i class="bi bi-file-earmark-text"></i><span>Dokument</span></button>
        </div>

        <!-- Text-Modus -->
        <div id="trBereichText" class="tr-text-grid">
            <div class="tr-text-pane">
                <div class="tr-pane-header">
                    <span class="tr-pane-title">Originaltext</span>
                    <span id="trErkannt" class="tr-pane-meta"></span>
                </div>
                <textarea id="trEingabe" class="tr-textarea" placeholder="Text hier einfügen…" oninput="trZeichenZaehlen()"></textarea>
                <div class="tr-pane-footer">
                    <span id="trZeichen" class="tr-zeichen">0 Zeichen</span>
                    <button class="tr-action-btn tr-action-primary" id="trBtnText" onclick="trTextUebersetzen()">
                        <i class="bi bi-translate"></i> Übersetzen
                    </button>
                </div>
            </div>
            <div class="tr-text-pane tr-text-pane-output">
                <div class="tr-pane-header">
                    <span class="tr-pane-title">Übersetzung</span>
                </div>
                <textarea id="trAusgabe" class="tr-textarea tr-textarea-output" readonly placeholder="Ergebnis erscheint hier…"></textarea>
                <div class="tr-pane-footer">
                    <span class="tr-zeichen" id="trZeichenAusgabe">&nbsp;</span>
                    <button class="tr-action-btn tr-action-secondary" id="trBtnCopy" onclick="trKopieren()" disabled>
                        <i class="bi bi-clipboard"></i> Kopieren
                    </button>
                </div>
            </div>
        </div>

        <!-- Datei-Modus -->
        <div id="trBereichFile" class="tr-file-bereich" style="display:none;">
            <div id="trFileHinweis" class="tr-file-hinweis"></div>
            <div class="tr-dropzone" onclick="document.getElementById('trDatei').click()"
                 ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
                 ondrop="event.preventDefault();this.classList.remove('dragover');trDateiSetzen(event.dataTransfer.files[0])">
                <div class="tr-dropzone-icon"><i class="bi bi-cloud-arrow-up"></i></div>
                <div class="tr-dropzone-title">Dokument hierher ziehen oder klicken</div>
                <div class="tr-dropzone-meta">DOCX · PPTX · XLSX · PDF · HTML · TXT · SRT · XLF · XLIFF</div>
                <input type="file" id="trDatei" accept=".docx,.pptx,.xlsx,.pdf,.html,.htm,.txt,.srt,.xlf,.xliff" style="display:none;" onchange="trDateiSetzen(this.files[0])" />
            </div>
            <div id="trDateiInfo" class="tr-datei-info" style="display:none;">
                <div id="trDateiName"></div>
                <div style="display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.75rem;">
                    <button class="tr-action-btn tr-action-primary" id="trBtnFile" onclick="trDateiUebersetzen()"><i class="bi bi-translate"></i> Dokument übersetzen</button>
                    <button class="tr-action-btn tr-action-ghost" onclick="trDateiLeeren()"><i class="bi bi-x"></i> Entfernen</button>
                </div>
            </div>
            <div id="trDateiResult" class="tr-datei-result" style="display:none;"></div>
        </div>
    </div>
</section>

<!-- KI-Chat (OpenAI) -->
<section class="mc-section" id="panel-kichat" style="display:none;">
    <div class="ki-card">
        <div class="ki-header">
            <div class="ki-header-left">
                <div class="ki-logo"><i class="bi bi-chat-dots"></i></div>
                <div>
                    <div class="ki-title">KI-Chat</div>
                    <div class="ki-subtitle">Powered by OpenAI · Anfragen laufen über euren internen Proxy</div>
                </div>
            </div>
            <div class="ki-header-right">
                <select id="kiModell" class="ki-modell-select" title="Modellwahl">
                    <option value="gpt-4o-mini" selected>gpt-4o-mini · schnell</option>
                    <option value="gpt-4o">gpt-4o · ausgewogen</option>
                    <option value="gpt-4.1">gpt-4.1 · stark</option>
                    <option value="gpt-4.1-mini">gpt-4.1-mini · effizient</option>
                </select>
                <button class="ki-action-ghost" onclick="kichatNeu()" title="Neuer Chat"><i class="bi bi-arrow-clockwise"></i></button>
                <button class="ki-close" onclick="toolSchliessen('kichat')" title="Schliessen"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div id="kiStatus" class="ki-banner" style="display:none;"></div>

        <div id="kiVerlauf" class="ki-verlauf">
            <!-- Initialnachricht beim Render -->
        </div>

        <div class="ki-eingabe">
            <textarea id="kiInput" rows="1" placeholder="Nachricht eingeben…  (Enter zum Senden, Shift+Enter für Zeilenumbruch)"
                      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();kichatSenden();}"
                      oninput="kiAutoResize(this)"></textarea>
            <button class="ki-send" id="kiSendBtn" onclick="kichatSenden()" title="Senden"><i class="bi bi-send"></i></button>
        </div>
    </div>
</section>

<!-- KI URL analysieren -->
<section class="mc-section" id="panel-kiurl" style="display:none;">
    <div class="ki-card" style="height:auto;">
        <div class="ki-header">
            <div class="ki-header-left">
                <div class="ki-logo" style="background:linear-gradient(135deg,#39747A,#10A37F);"><i class="bi bi-globe2"></i></div>
                <div>
                    <div class="ki-title">URL analysieren</div>
                    <div class="ki-subtitle">Webseite laden, durch Proxy holen und KI-gestützt aufbereiten</div>
                </div>
            </div>
            <div class="ki-header-right">
                <button class="ki-action-ghost" onclick="kiurlReset()" title="Neu starten"><i class="bi bi-arrow-clockwise"></i></button>
                <button class="ki-close" onclick="toolSchliessen('kiurl')" title="Schliessen"><i class="bi bi-x-lg"></i></button>
            </div>
        </div>

        <div id="kiurlStatus" class="ki-banner" style="display:none;"></div>

        <div style="padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:1rem;">
            <div>
                <label style="display:block; font-size:.78rem; font-weight:600; letter-spacing:.05em; color:var(--mc-text-muted); text-transform:uppercase; margin-bottom:.4rem;">Webseite (URL)</label>
                <input id="kiurlInput" type="url" placeholder="https://www.beispiel.de/artikel"
                    style="width:100%; padding:.7rem .9rem; border:1px solid var(--mc-border); border-radius:10px; font-size:.95rem; background:var(--mc-bg-card); color:var(--mc-text-dark); outline:none;"
                    onfocus="this.style.borderColor='#10A37F'" onblur="this.style.borderColor='var(--mc-border)'" />
            </div>

            <div>
                <label style="display:block; font-size:.78rem; font-weight:600; letter-spacing:.05em; color:var(--mc-text-muted); text-transform:uppercase; margin-bottom:.4rem;">Was soll die KI mit dem Inhalt machen?</label>
                <div class="kiurl-aktion-grid">
                    <label class="kiurl-aktion"><input type="radio" name="kiurlAktion" value="zusammenfassen" checked /><span><i class="bi bi-list-ul"></i> Zusammenfassen</span></label>
                    <label class="kiurl-aktion"><input type="radio" name="kiurlAktion" value="erklaeren" /><span><i class="bi bi-question-circle"></i> Erklären</span></label>
                    <label class="kiurl-aktion"><input type="radio" name="kiurlAktion" value="uebersetzen" /><span><i class="bi bi-translate"></i> Übersetzen</span></label>
                    <label class="kiurl-aktion"><input type="radio" name="kiurlAktion" value="frage" /><span><i class="bi bi-chat-dots"></i> Frage stellen</span></label>
                </div>
            </div>

            <div id="kiurlExtra" style="display:none;">
                <label id="kiurlExtraLabel" style="display:block; font-size:.78rem; font-weight:600; letter-spacing:.05em; color:var(--mc-text-muted); text-transform:uppercase; margin-bottom:.4rem;"></label>
                <input id="kiurlExtraInput" type="text"
                    style="width:100%; padding:.7rem .9rem; border:1px solid var(--mc-border); border-radius:10px; font-size:.95rem; background:var(--mc-bg-card); color:var(--mc-text-dark); outline:none;"
                    onfocus="this.style.borderColor='#10A37F'" onblur="this.style.borderColor='var(--mc-border)'" />
            </div>

            <div style="display:flex; gap:.5rem; align-items:center;">
                <button id="kiurlBtn" onclick="kiurlAnalysieren()"
                    style="padding:.65rem 1.4rem; border:none; border-radius:10px; background:linear-gradient(135deg,#10A37F,#1A7F64); color:#fff; font-weight:600; font-size:.9rem; cursor:pointer; box-shadow:0 4px 12px rgba(16,163,127,.35);">
                    <i class="bi bi-magic"></i> Analysieren
                </button>
                <span id="kiurlInfo" style="font-size:.78rem; color:var(--mc-text-muted);"></span>
            </div>

            <div id="kiurlErgebnis" class="ki-msg-bubble" style="display:none; background:var(--mc-bg-alt); border:1px solid var(--mc-border); padding:1rem 1.15rem; border-radius:14px;"></div>
        </div>
    </div>
</section>

<!-- OCR / Handschrift (Spielwiese) -->
<section class="mc-section" id="panel-ocr" style="display:none;">
    <div class="mc-section-title" style="border-bottom-color:var(--mc-warning);"><i class="bi bi-fonts" style="color:var(--mc-warning) !important;"></i> Text aus Scan / Handschrift <span style="background:var(--mc-warning);color:#fff;font-size:.65rem;font-weight:600;padding:.15rem .45rem;border-radius:999px;letter-spacing:.04em;margin-left:.5rem;">SPIELWIESE</span> <button onclick="toolSchliessen('ocr')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <!-- Deutlicher Warnhinweis -->
        <div style="background:linear-gradient(135deg,rgba(167,12,35,.08),rgba(222,98,80,.06));border:1px solid rgba(167,12,35,.3);border-left:4px solid var(--mc-danger);border-radius:var(--mc-radius-sm);padding:1rem 1.15rem;margin-bottom:1.25rem;">
            <div style="display:flex;align-items:flex-start;gap:.75rem;">
                <i class="bi bi-exclamation-triangle-fill" style="color:var(--mc-danger);font-size:1.4rem;flex-shrink:0;margin-top:.1rem;"></i>
                <div>
                    <div style="font-weight:700;color:var(--mc-danger);margin-bottom:.4rem;font-size:.95rem;">
                        Erwartungs-Hinweis: Die Qualität dieses Tools ist miserabel.
                    </div>
                    <div style="font-size:.85rem;color:var(--mc-text-dark);line-height:1.55;">
                        Funktioniert <strong>höchstwahrscheinlich nur bei sehr sauberer, gleichmässiger Druckschrift</strong> (Block-/Maschinenschrift). Bei normaler Handschrift, kursiv, schräggestellt, unterschiedlichen Stiftdicken oder schlechter Scan-Qualität ist die Erkennung <strong>unbrauchbar</strong>.
                    </div>
                    <div style="font-size:.78rem;color:var(--mc-text-muted);margin-top:.55rem;line-height:1.5;">
                        Bitte stelle dich darauf ein, dass das Ergebnis oft nicht verwertbar ist. Das ist eine experimentelle Funktion in der Spielwiese — keine Erwartung an Genauigkeit. Für gedruckte PDFs mit Text-Layer nutze bitte <strong>„Text aus PDF extrahieren"</strong> aus den PDF-Werkzeugen.
                    </div>
                </div>
            </div>
        </div>
        <div class="upload-zone" onclick="document.getElementById('ocrFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');ocrStart(event.dataTransfer.files[0])">
            <i class="bi bi-fonts" style="font-size:2.5rem; color:#39747A;"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">Eingescanntes PDF hierher ziehen oder klicken</div>
            <div style="font-size:.75rem; color:var(--mc-text-muted); margin-top:.35rem;">Texterkennung dauert je nach Seitenzahl 5–30 Sekunden pro Seite</div>
            <input type="file" id="ocrFile" accept=".pdf" style="display:none;" onchange="ocrStart(this.files[0])" />
        </div>
        <div class="result-card" id="ocrResult"></div>
    </div>
</section>

<!-- PDF Info -->
<section class="mc-section" id="panel-info" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-info-circle"></i> PDF-Informationen <button onclick="toolSchliessen('info')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" onclick="document.getElementById('infoFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');infoAnalyze(event.dataTransfer.files[0])">
            <i class="bi bi-info-circle" style="font-size:2.5rem; color:#6C4562;"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">PDF hierher ziehen oder klicken</div>
            <input type="file" id="infoFile" accept=".pdf" style="display:none;" onchange="infoAnalyze(this.files[0])" />
        </div>
        <div class="result-card" id="infoResult"></div>
    </div>
</section>

<!-- Dokument → PDF -->
<section class="mc-section" id="panel-convert" style="display:none;">
    <div class="mc-section-title"><i class="bi bi-file-earmark-arrow-down"></i> Dokument → PDF <button onclick="toolSchliessen('convert')" style="margin-left:auto;background:none;border:none;cursor:pointer;color:var(--mc-text-muted);font-size:1rem;"><i class="bi bi-x-lg"></i></button></div>
    <div class="mc-card">
        <div class="upload-zone" onclick="document.getElementById('convertFile').click()"
             ondragover="event.preventDefault();this.classList.add('dragover')" ondragleave="this.classList.remove('dragover')"
             ondrop="event.preventDefault();this.classList.remove('dragover');convertStart(event.dataTransfer.files[0])">
            <i class="bi bi-file-earmark-arrow-down" style="font-size:2.5rem; color:#DE6250;"></i>
            <div style="margin-top:.5rem; color:var(--mc-text-muted);">Dokument hierher ziehen oder klicken</div>
            <div style="font-size:.75rem; color:var(--mc-text-muted); margin-top:.35rem;">Word (.docx/.doc) · Excel (.xlsx/.xls) · PowerPoint (.pptx) · OpenDocument · RTF · TXT · HTML · CSV</div>
            <input type="file" id="convertFile" accept=".docx,.doc,.xlsx,.xls,.pptx,.ppt,.odt,.ods,.odp,.rtf,.txt,.html,.csv" style="display:none;" onchange="convertStart(this.files[0])" />
        </div>
        <div class="result-card" id="convertResult"></div>
    </div>
</section>

@section Scripts {
<script>
// Globale Tool-Verwaltung
let _aktivesTool = null;
const ALLE_TOOLS = ['encrypt','convert','text','ocr','translate','split','merge','info','kichat','kiurl'];
const TOOL_ZU_HOLDER = {
    encrypt: 'holder-pdf', convert: 'holder-pdf', text: 'holder-pdf',
    split:   'holder-pdf', merge:   'holder-pdf', info:  'holder-pdf',
    translate: 'holder-uebersetzen',
    kichat:    'holder-ki',
    kiurl:     'holder-ki',
    ocr:       'holder-spielwiese'
};

function toolOeffnen(id, modus) {
    // Sonderfall Translate: gleiche Kachel + gleicher Modus → toggeln zu
    if (id === 'translate' && modus) {
        if (_aktivesTool === 'translate' && _trModus === modus) { toolSchliessen('translate'); return; }
        if (_aktivesTool === 'translate' && _trModus !== modus) { trSetzeModus(modus); return; }
    }
    // Toggle für andere Tools
    if (_aktivesTool === id && id !== 'translate') { toolSchliessen(id); return; }
    if (_aktivesTool && _aktivesTool !== id) toolSchliessen(_aktivesTool);

    const panel = document.getElementById('panel-' + id);
    if (!panel) return;

    const holderId = TOOL_ZU_HOLDER[id];
    const holder = holderId ? document.getElementById(holderId) : null;
    if (holder && panel.parentElement !== holder) holder.appendChild(panel);

    panel.style.display = '';
    if (id === 'translate' && modus) trSetzeModus(modus);
    if (id === 'kichat') kichatVorOeffnen();
    if (id === 'kiurl') kiurlInit();

    setTimeout(() => {
        const topbarH = document.querySelector('.mc-topbar')?.offsetHeight || 64;
        const y = panel.getBoundingClientRect().top + window.pageYOffset - topbarH - 12;
        window.scrollTo({ top: y, behavior: 'smooth' });
    }, 30);
    _aktivesTool = id;
}
function toolSchliessen(id) {
    const panel = document.getElementById('panel-' + id);
    if (panel) panel.style.display = 'none';
    toolReset(id);
    if (_aktivesTool === id) _aktivesTool = null;
}
function toolReset(id) {
    switch (id) {
        case 'encrypt':   encryptReset();   break;
        case 'merge':     mergeReset();     break;
        case 'split':     splitReset();     break;
        case 'text':      textReset();      break;
        case 'ocr':       ocrReset();       break;
        case 'translate': translateReset(); break;
        case 'kichat':    kichatReset();    break;
        case 'kiurl':     kiurlReset();     break;
        case 'info':      infoReset();      break;
        case 'convert':   convertReset();   break;
    }
}

// Download-Cache pro Tool
let mergeBlob = null;
let convertBlob = null, convertName = '';
let encryptBlob = null, encryptName = '';
let encryptOriginalFile = null;

// Direkter Download für PDF-Tools — ohne Speichern-Dialog
function pdfDirektDownload(blob, name) {
    if (!blob) return;
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = name || 'datei.pdf';
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1500);
}

// Reset-Funktionen (jeweils: Datei-Inputs, Result-Bereiche, State)
function encryptReset() {
    const f = document.getElementById('encryptFile'); if (f) f.value = '';
    const r = document.getElementById('encryptResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
    encryptBlob = null; encryptName = ''; encryptOriginalFile = null;
}
function mergeReset() {
    mergeFileList = [];
    const f = document.getElementById('mergeFiles'); if (f) f.value = '';
    const list = document.getElementById('mergeList'); if (list) list.innerHTML = '';
    const r = document.getElementById('mergeResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
    mergeBlob = null;
}
function splitReset() {
    splitCurrentFile = null;
    const f = document.getElementById('splitFile'); if (f) f.value = '';
    const info = document.getElementById('splitInfo'); if (info) info.style.display = 'none';
    const von = document.getElementById('splitVon'); if (von) von.value = 1;
    const bis = document.getElementById('splitBis'); if (bis) bis.value = '';
}
function textReset() {
    const f = document.getElementById('textFile'); if (f) f.value = '';
    const r = document.getElementById('textResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
}
function ocrReset() {
    const f = document.getElementById('ocrFile'); if (f) f.value = '';
    const r = document.getElementById('ocrResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
}
function infoReset() {
    const f = document.getElementById('infoFile'); if (f) f.value = '';
    const r = document.getElementById('infoResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
}
function convertReset() {
    const f = document.getElementById('convertFile'); if (f) f.value = '';
    const r = document.getElementById('convertResult');
    if (r) { r.innerHTML = ''; r.style.display = 'none'; }
    convertBlob = null; convertName = '';
}

function formatSize(b) { return b < 1024*1024 ? (b/1024).toFixed(0) + ' KB' : (b/1024/1024).toFixed(1) + ' MB'; }

// ═══ PDF Merge ═══
let mergeFileList = [];
function mergeAddFiles(files) {
    for (const f of files) { if (f.name.endsWith('.pdf')) mergeFileList.push(f); }
    mergeRender();
}
function mergeRemove(idx) { mergeFileList.splice(idx, 1); mergeRender(); }
function mergeClear() { mergeFileList = []; mergeRender(); }
function mergeRender() {
    const el = document.getElementById('mergeList');
    el.innerHTML = mergeFileList.map((f, i) =>
        `<div class="file-item"><i class="bi bi-file-earmark-pdf"></i> ${f.name} <span class="file-size">${formatSize(f.size)}</span> <button class="file-remove" onclick="mergeRemove(${i})"><i class="bi bi-x"></i></button></div>`
    ).join('');
}
async function mergeStart() {
    if (mergeFileList.length < 2) { mcAlert('Mindestens 2 PDF-Dateien erforderlich.', { variante: 'warn', icon: 'bi-exclamation-circle' }); return; }
    const btn = document.getElementById('mergeBtn');
    btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Wird zusammengeführt...';
    const fd = new FormData();
    mergeFileList.forEach(f => fd.append('dateien', f));
    try {
        const r = await fetch('/api/PdfMerge', { method: 'POST', body: fd });
        if (r.headers.get('content-type')?.includes('pdf')) {
            mergeBlob = await r.blob();
            const res = document.getElementById('mergeResult');
            res.style.display = 'block';
            res.innerHTML = `<div style="display:flex;align-items:center;gap:.75rem;"><i class="bi bi-check-circle-fill" style="color:var(--mc-success);font-size:1.3rem;"></i><div><strong>${mergeFileList.length} PDFs zusammengeführt</strong></div><button class="btn-mc btn-mc-filled" onclick="pdfDirektDownload(mergeBlob,'zusammengefuehrt.pdf')" style="margin-left:auto;font-size:.82rem;"><i class="bi bi-download"></i> Herunterladen</button></div>`;
        } else {
            const d = await r.json();
            mcError(d.error || 'Zusammenführen fehlgeschlagen.');
        }
    } catch { mcError('Fehler bei der Zusammenführung.'); }
    finally { btn.disabled = false; btn.innerHTML = '<i class="bi bi-files"></i> Zusammenführen'; }
}

// ═══ PDF Split ═══
let splitCurrentFile = null;
function splitSetFile(f) {
    if (!f) return;
    splitCurrentFile = f;
    document.getElementById('splitFileName').textContent = f.name + ' (' + formatSize(f.size) + ')';
    document.getElementById('splitInfo').style.display = 'block';
    // Get page count
    const fd = new FormData(); fd.append('datei', f);
    fetch('/api/PdfInfo', { method: 'POST', body: fd }).then(r => r.json()).then(d => {
        if (d.seiten) { document.getElementById('splitBis').value = d.seiten; document.getElementById('splitBis').max = d.seiten; document.getElementById('splitVon').max = d.seiten; }
    });
}
async function splitStart() {
    if (!splitCurrentFile) return;
    const von = document.getElementById('splitVon').value;
    const bis = document.getElementById('splitBis').value;
    const fd = new FormData();
    fd.append('datei', splitCurrentFile);
    fd.append('vonSeite', von); fd.append('bisSeite', bis);
    const r = await fetch('/api/PdfSplit', { method: 'POST', body: fd });
    if (r.headers.get('content-type')?.includes('pdf')) {
        const blob = await r.blob();
        pdfDirektDownload(blob, `seiten_${von}-${bis}.pdf`);
    } else { const d = await r.json(); mcError(d.error || 'Aufteilen fehlgeschlagen.'); }
}

// ═══ PDF Text ═══
async function textExtract(f) {
    if (!f) return;
    const res = document.getElementById('textResult');
    res.style.display = 'block';
    res.innerHTML = '<div style="text-align:center;padding:1rem;color:var(--mc-text-muted);"><i class="bi bi-hourglass-split"></i> Text wird extrahiert...</div>';
    const fd = new FormData(); fd.append('datei', f);
    const r = await fetch('/api/PdfText', { method: 'POST', body: fd });
    const d = await r.json();
    if (d.error) { res.innerHTML = '<div style="color:var(--mc-danger);">' + d.error + '</div>'; return; }
    res.innerHTML = `<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;">
        <strong>${f.name} — ${d.seiten} Seiten</strong>
        <button class="btn-mc btn-mc-primary" onclick="navigator.clipboard.writeText(document.getElementById('extractedText').value);this.innerHTML='<i class=\\'bi bi-check\\'></i> Kopiert'" style="font-size:.78rem;"><i class="bi bi-clipboard"></i> Kopieren</button>
    </div><textarea id="extractedText" readonly style="width:100%;height:300px;padding:.75rem;border:1px solid var(--mc-border);border-radius:var(--mc-radius-sm);font-family:monospace;font-size:.8rem;background:var(--mc-bg-alt);color:var(--mc-text);resize:vertical;">${d.text.replace(/</g,'&lt;')}</textarea>`;
}

// ═══ Dokument → PDF ═══
async function convertStart(f) {
    if (!f) return;
    const res = document.getElementById('convertResult');
    res.style.display = 'block';
    res.innerHTML = `<div style="display:flex;align-items:center;gap:.75rem;padding:.5rem;"><i class="bi bi-hourglass-split" style="color:var(--mc-petrol);"></i> <span>${f.name} wird konvertiert... (kann einige Sekunden dauern)</span></div>`;
    const fd = new FormData(); fd.append('datei', f);
    try {
        const r = await fetch('/api/ConvertToPdf', { method: 'POST', body: fd });
        if (r.headers.get('content-type')?.includes('pdf')) {
            convertBlob = await r.blob();
            convertName = f.name.replace(/\.[^.]+$/, '.pdf');
            res.innerHTML = `<div style="display:flex;align-items:center;gap:.75rem;">
                <i class="bi bi-check-circle-fill" style="color:var(--mc-success);font-size:1.3rem;"></i>
                <div><strong>${f.name}</strong> → <strong>${convertName}</strong></div>
                <button class="btn-mc btn-mc-filled" onclick="pdfDirektDownload(convertBlob, convertName)" style="margin-left:auto;font-size:.82rem;"><i class="bi bi-download"></i> PDF herunterladen</button>
            </div>`;
        } else {
            const d = await r.json();
            res.innerHTML = `<div style="color:var(--mc-danger);"><i class="bi bi-exclamation-triangle"></i> ${d.error || 'Konvertierung fehlgeschlagen'}</div>`;
        }
    } catch { res.innerHTML = '<div style="color:var(--mc-danger);">Verbindungsfehler</div>'; }
}

// ═══ KI-Chat (OpenAI) ═══
let _kiVerlauf = [];
let _kiBesetzt = false;
let _kiInitiiert = false;

function kichatInit() {
    if (_kiInitiiert) return;
    _kiInitiiert = true;
    kichatLeerenZuInitial();
    kichatStatusLaden();
}

async function kichatVorOeffnen() {
    const ok = await mcModal({
        titel: 'Hinweise zum Einsatz der KI',
        icon: 'bi-shield-check',
        variante: 'warn',
        html: `
            <div style="line-height:1.6; font-size:.92rem;">
                Bevor du den KI-Assistenten nutzt, bitte folgende Punkte beachten:
                <ul style="margin:.75rem 0 .75rem 1.15rem; padding:0;">
                    <li><strong>Datenschutz (DSGVO):</strong> Keine personenbezogenen Daten von Kund:innen, Kolleg:innen oder Dritten eingeben — keine Namen, Kontonummern, IBAN, Adressen, Geburtsdaten o. ä.</li>
                    <li><strong>Bankgeheimnis:</strong> Keine vertraulichen Geschäfts- oder Mandatsinformationen teilen.</li>
                    <li><strong>Antworten prüfen:</strong> KI-Antworten können falsch oder unvollständig sein. Vor Weiterverwendung kritisch verifizieren.</li>
                    <li><strong>Verantwortung:</strong> Die fachliche und rechtliche Verantwortung liegt weiterhin bei dir.</li>
                </ul>
                <div style="font-size:.82rem; color:var(--mc-text-muted);">Anfragen werden über den internen Bank-Proxy an OpenAI übermittelt.</div>
            </div>`,
        okText: 'Verstanden',
        bestaetigung: false
    });
    if (ok === false) {
        toolSchliessen('kichat');
        return;
    }
    kichatInit();
}

async function kichatStatusLaden() {
    const banner = document.getElementById('kiStatus');
    try {
        const r = await fetch('/api/KiChatStatus');
        const d = await r.json();
        if (!d.konfiguriert) {
            banner.style.display = 'block';
            banner.style.background = 'rgba(222,98,80,.1)';
            banner.style.color = 'var(--mc-warning)';
            banner.innerHTML = '<i class="bi bi-exclamation-triangle-fill"></i> <strong>OpenAI noch nicht konfiguriert.</strong> Setze in der <code style="background:rgba(0,0,0,.06);padding:.05rem .3rem;border-radius:3px;">web.config</code> die Environment-Variable <code style="background:rgba(0,0,0,.06);padding:.05rem .3rem;border-radius:3px;">OPENAI_API_KEY</code> und starte den App-Pool neu.';
            return;
        }
        banner.style.display = 'none';
    } catch {}
}

function kichatLeerenZuInitial() {
    const v = document.getElementById('kiVerlauf');
    v.innerHTML = `<div class="ki-msg ki-msg-assistant">
        <div class="ki-msg-avatar"><i class="bi bi-stars"></i></div>
        <div class="ki-msg-bubble">
            <strong>Hallo!</strong> Ich bin der KI-Chat-Assistent von MerkurTools — basierend auf OpenAI, alle Anfragen laufen über euren internen Proxy.<br><br>
            Beispiele was du fragen kannst:
            <ul style="margin:.5rem 0 0 1.1rem;">
                <li>„Erkläre mir die DSGVO-Pflichten beim Versand von Kundendokumenten."</li>
                <li>„Wie formuliere ich diese E-Mail höflicher?"</li>
                <li>„Was bedeuten die Begriffe X, Y, Z?"</li>
                <li>„Schreibe mir einen kurzen Entwurf für …"</li>
            </ul>
        </div>
    </div>`;
    _kiVerlauf = [];
}

function kichatNeu() {
    if (_kiBesetzt) return;
    kichatLeerenZuInitial();
    document.getElementById('kiInput').value = '';
    kiAutoResize(document.getElementById('kiInput'));
}

function kichatReset() {
    _kiVerlauf = [];
    document.getElementById('kiInput').value = '';
    if (_kiInitiiert) kichatLeerenZuInitial();
}

function kiAutoResize(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 200) + 'px';
}

function kichatBubbleHinzu(rolle, text, alsHTML) {
    const v = document.getElementById('kiVerlauf');
    const wrap = document.createElement('div');
    wrap.className = 'ki-msg ki-msg-' + rolle;
    const avatar = document.createElement('div');
    avatar.className = 'ki-msg-avatar';
    avatar.innerHTML = rolle === 'user' ? '<i class="bi bi-person"></i>' : '<i class="bi bi-stars"></i>';
    const bubble = document.createElement('div');
    bubble.className = 'ki-msg-bubble';
    if (alsHTML) bubble.innerHTML = text;
    else bubble.textContent = text;
    wrap.appendChild(avatar); wrap.appendChild(bubble);
    v.appendChild(wrap);
    v.scrollTop = v.scrollHeight;
    return bubble;
}

function kichatTippenAnzeigen() {
    const b = kichatBubbleHinzu('assistant', '<div class="ki-typing"><span></span><span></span><span></span></div>', true);
    b.dataset.typing = '1';
    return b.parentElement;
}

async function kichatSenden() {
    if (_kiBesetzt) return;
    const inp = document.getElementById('kiInput');
    const txt = inp.value.trim();
    if (!txt) return;
    _kiBesetzt = true;
    inp.value = ''; kiAutoResize(inp);
    document.getElementById('kiSendBtn').disabled = true;

    kichatBubbleHinzu('user', txt, false);
    const tippen = kichatTippenAnzeigen();

    try {
        const fd = new FormData();
        fd.append('nachricht', txt);
        fd.append('verlauf', JSON.stringify(_kiVerlauf));
        fd.append('modell', document.getElementById('kiModell').value);
        const r = await fetch('/api/KiChat', { method: 'POST', body: fd });
        const d = await r.json();
        tippen.remove();
        if (d.error) {
            kichatBubbleHinzu('assistant', '<span style="color:var(--mc-danger);"><i class="bi bi-exclamation-triangle"></i> ' + d.error + '</span>', true);
        } else {
            kichatBubbleHinzu('assistant', kichatMarkdown(d.antwort || '(leere Antwort)'), true);
            _kiVerlauf.push({ rolle: 'user', text: txt });
            _kiVerlauf.push({ rolle: 'assistant', text: d.antwort || '' });
            if (_kiVerlauf.length > 24) _kiVerlauf = _kiVerlauf.slice(-24);
        }
    } catch (e) {
        tippen.remove();
        kichatBubbleHinzu('assistant', '<span style="color:var(--mc-danger);"><i class="bi bi-exclamation-triangle"></i> Verbindungsfehler.</span>', true);
    } finally {
        _kiBesetzt = false;
        document.getElementById('kiSendBtn').disabled = false;
        inp.focus();
    }
}

function kichatMarkdown(raw) {
    if (!raw) return '';
    let s = raw.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    s = s.replace(/```(\w*)\n?([\s\S]*?)```/g, (m, lang, code) => `<pre>${code.trim()}</pre>`);
    s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
    s = s.replace(/((?:\|.+\|(?:\n|$))+)/g, function(tableBlock) {
        const rows = tableBlock.trim().split('\n').filter(r => r.trim());
        if (rows.length < 2) return tableBlock;
        let html = '<table>';
        rows.forEach((row, idx) => {
            if (row.match(/^\|[\s\-:|]+\|$/)) return;
            const cells = row.split('|').filter((c, i, a) => i > 0 && i < a.length - 1);
            const tag = idx === 0 ? 'th' : 'td';
            html += '<tr>' + cells.map(c => `<${tag}>${c.trim()}</${tag}>`).join('') + '</tr>';
        });
        return html + '</table>';
    });
    s = s.replace(/^####\s+(.+)$/gm, '<h4 style="margin:.6rem 0 .3rem;font-size:.9rem;font-weight:600;">$1</h4>');
    s = s.replace(/^###\s+(.+)$/gm, '<h3 style="margin:.7rem 0 .3rem;font-size:.95rem;font-weight:600;">$1</h3>');
    s = s.replace(/^##\s+(.+)$/gm, '<h2 style="margin:.8rem 0 .35rem;font-size:1rem;font-weight:600;">$1</h2>');
    s = s.replace(/^#\s+(.+)$/gm, '<h1 style="margin:.8rem 0 .35rem;font-size:1.1rem;font-weight:700;">$1</h1>');
    s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    s = s.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');
    s = s.replace(/(^|\n)((?:\d+\.\s+.+(?:\n|$))+)/g, (m, p, list) => {
        const items = list.split('\n').map(l => l.replace(/^\d+\.\s+/,'').trim()).filter(x=>x);
        return p + '<ol>' + items.map(i => '<li>'+i+'</li>').join('') + '</ol>';
    });
    s = s.replace(/(^|\n)(\s*[-*]\s+.+(?:\n\s*[-*]\s+.+)*)/g, (m, p, list) => {
        const items = list.split('\n').map(l => l.replace(/^\s*[-*]\s+/,'').trim()).filter(x=>x);
        return p + '<ul>' + items.map(i => '<li>'+i+'</li>').join('') + '</ul>';
    });
    const parts = s.split(/\n{2,}/);
    return parts.map(p => {
        p = p.trim(); if (!p) return '';
        if (/^<(h[1-6]|ul|ol|pre|table)/.test(p)) return p;
        return '<p style="margin:0 0 .5rem;line-height:1.55;">' + p.replace(/\n/g,'<br/>') + '</p>';
    }).join('');
}

// ═══ KI URL analysieren ═══
let _kiurlInit = false;

function kiurlInit() {
    if (_kiurlInit) return;
    _kiurlInit = true;
    document.querySelectorAll('input[name="kiurlAktion"]').forEach(r => {
        r.addEventListener('change', kiurlAktionGeaendert);
    });
    kiurlAktionGeaendert();
}

function kiurlAktionGeaendert() {
    const wahl = document.querySelector('input[name="kiurlAktion"]:checked')?.value;
    const extra = document.getElementById('kiurlExtra');
    const lab = document.getElementById('kiurlExtraLabel');
    const inp = document.getElementById('kiurlExtraInput');
    if (wahl === 'uebersetzen') {
        extra.style.display = 'block';
        lab.textContent = 'Zielsprache (z. B. Englisch, Französisch, …)';
        inp.placeholder = 'Englisch';
    } else if (wahl === 'frage') {
        extra.style.display = 'block';
        lab.textContent = 'Deine Frage zum Inhalt';
        inp.placeholder = 'Was wird hier konkret zur DSGVO ausgeführt?';
    } else {
        extra.style.display = 'none';
        inp.value = '';
    }
}

async function kiurlAnalysieren() {
    const url = document.getElementById('kiurlInput').value.trim();
    if (!url) { mcAlert('Bitte eine URL eingeben.', { variante: 'warn', icon: 'bi-globe2' }); return; }
    if (!/^https?:\/\//i.test(url)) { mcAlert('URL muss mit http:// oder https:// beginnen.', { variante: 'warn' }); return; }

    const aktion = document.querySelector('input[name="kiurlAktion"]:checked')?.value || 'zusammenfassen';
    const extra = document.getElementById('kiurlExtraInput')?.value.trim() || '';

    if (aktion === 'frage' && !extra) { mcAlert('Bitte eine Frage eingeben.', { variante: 'warn' }); return; }

    const btn = document.getElementById('kiurlBtn');
    const info = document.getElementById('kiurlInfo');
    const erg = document.getElementById('kiurlErgebnis');
    btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Wird analysiert…';
    info.textContent = 'Webseite wird geladen und an die KI übermittelt…';
    erg.style.display = 'none'; erg.innerHTML = '';

    try {
        const fd = new FormData();
        fd.append('url', url);
        fd.append('aktion', aktion);
        fd.append('extra', extra);
        const r = await fetch('/api/KiUrl', { method: 'POST', body: fd });
        const d = await r.json();
        if (d.error) {
            erg.style.display = 'block';
            erg.innerHTML = `<div style="color:var(--mc-danger);"><i class="bi bi-exclamation-triangle"></i> ${d.error}</div>`;
            info.textContent = '';
            return;
        }
        erg.style.display = 'block';
        erg.innerHTML = `
            <div style="font-size:.78rem; color:var(--mc-text-muted); margin-bottom:.6rem; display:flex; gap:.5rem; align-items:center; flex-wrap:wrap;">
                <i class="bi bi-globe2" style="color:#10A37F;"></i>
                <span>Quelle: <strong>${(d.titel || '').replace(/</g,'&lt;') || url}</strong></span>
                ${d.zeichen ? '<span style="color:var(--mc-text-muted);">·</span><span>' + d.zeichen.toLocaleString('de-DE') + ' Zeichen analysiert</span>' : ''}
            </div>
            ${kichatMarkdown(d.antwort || '(leere Antwort)')}`;
        info.textContent = '';
    } catch (e) {
        erg.style.display = 'block';
        erg.innerHTML = '<div style="color:var(--mc-danger);">Verbindungsfehler bei der Analyse.</div>';
        info.textContent = '';
    } finally {
        btn.disabled = false; btn.innerHTML = '<i class="bi bi-magic"></i> Analysieren';
    }
}

function kiurlReset() {
    document.getElementById('kiurlInput').value = '';
    document.getElementById('kiurlExtraInput').value = '';
    const erg = document.getElementById('kiurlErgebnis'); if (erg) { erg.style.display = 'none'; erg.innerHTML = ''; }
    const r = document.querySelector('input[name="kiurlAktion"][value="zusammenfassen"]'); if (r) r.checked = true;
    kiurlAktionGeaendert();
    document.getElementById('kiurlInfo').textContent = '';
}

